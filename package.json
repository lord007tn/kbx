{
  "name": "kbx",
  "version": "0.1.0",
  "description": "Local-first knowledge base CLI for searchable AI context.",
  "type": "module",
  "bin": {
    "kbx": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node20 --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@huggingface/transformers": "^3.8.1",
    "@paralleldrive/cuid2": "^2.3.0",
    "@zvec/zvec": "^0.3.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
