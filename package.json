{
  "name": "kbx",
  "version": "0.1.0",
  "description": "Local-first knowledge base CLI for searchable AI context.",
  "type": "module",
  "bin": {
    "kbx": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown src/cli.ts --format esm --target node20 --platform node --dts --clean",
    "dev": "tsx src/cli.ts",
    "example:hf-markdown": "node examples/hf-open-markdown/fetch-open-markdown.mjs",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@paralleldrive/cuid2": "^2.3.0",
    "@zvec/zvec": "^0.3.2",
    "chokidar": "^4.0.3",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "hyparquet": "^1.25.6",
    "hyparquet-compressors": "^1.1.1",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
