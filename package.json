{
  "name": "@lord007tn/kbx",
  "version": "0.1.0",
  "description": "Local-first knowledge base CLI for searchable AI context.",
  "license": "MIT",
  "keywords": [
    "knowledge-base",
    "rag",
    "mcp",
    "local-first",
    "vector-search",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lord007tn/kbx.git"
  },
  "bugs": {
    "url": "https://github.com/lord007tn/kbx/issues"
  },
  "homepage": "https://github.com/lord007tn/kbx#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "kbx": "dist/cli.mjs"
  },
  "files": [
    "dist/cli.mjs",
    "dist/cli.d.mts",
    ".claude-plugin/marketplace.json",
    "plugins/claude-code/kbx"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsdown",
    "bench:projects": "node --import tsx scripts/benchmark-projects.ts",
    "release:github": "changelogithub",
    "release:preflight": "npm run typecheck && npm test && npm run build && npm run smoke:pack && npm run smoke:install",
    "smoke:install": "node scripts/smoke-install.mjs",
    "smoke:pack": "node scripts/verify-npm-pack.mjs",
    "dev": "tsx src/cli.ts",
    "example:hf-markdown": "node examples/hf-open-markdown/fetch-open-markdown.mjs",
    "test": "node scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@zvec/zvec": "^0.3.2",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.4.1"
  },
  "overrides": {
    "@babel/helper-string-parser": "8.0.0-rc.4",
    "c12": "^3.3.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "changelogithub": "^14.0.0",
    "hyparquet": "^1.25.6",
    "hyparquet-compressors": "^1.1.1",
    "tsdown": "^0.22.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
